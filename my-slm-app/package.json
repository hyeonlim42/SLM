{
  "name": "local-ai-app",
  "version": "1.0.0",
  "description": "Desktop AI App",
  "author": "Your Name",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.myname.aiapp",
    "mac": { 
      "category": "public.app-category.productivity",
      "target": "dmg",
      "identity": null
    },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  }
}
